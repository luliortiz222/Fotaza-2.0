doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza - Home
    link(rel="stylesheet", href="/css/estilos.css") 
  body
    header
      nav.navbar
        div.nav-logo
          a(href="/") FOTAZA
        div.nav-links
          if nombreUsuario
            span.user-badge ¡Hola, @#{nombreUsuario}!
            a.btn-logout(href="/api/usuarios/logout") Cerrar Sesión
          else
            a(href="/login") Iniciar Sesión
            a(href="/registro") Registro
    
    main.container
      section.welcome-section
        h2 ¡Bienvenido a tu Feed!
        p Descubre las fotos que la comunidad está compartiendo.

      .feed-grid
        each pub in publicaciones
          .pub-card
            img(src=pub.urlImagen, alt=pub.titulo)
            .card-body
              h3= pub.titulo
              p= pub.descripcion
              p.user-tag @#{pub.Usuario ? pub.Usuario.usuario : 'Anónimo'}
              
              .stars-container
                - for (let i = 5; i >= 1; i--)
                  input(type="radio" id=`star${i}-${pub.id}` name=`rating-${pub.id}` value=i)
                  label(for=`star${i}-${pub.id}`) ★
                if usuarioId && Number(usuarioId) === Number(pub.usuarioId)
                .dropdown
                  input(type="checkbox" id=`menu-${pub.id}` class="dropdown-toggle")
                  label(for=`menu-${pub.id}` class="dropdown-label") ⋮
                  .dropdown-menu
                    form(action=`/api/publicaciones/eliminar/${pub.id}`, method="POST", onsubmit="return confirm('¿Seguro que deseas eliminar esta publicación?');")
                      button.btn-delete(type="submit") Eliminar
        else
          p.no-pub No hay fotos todavía. ¡Sé el primero en publicar!

      a.btn-create(href="/api/publicaciones/crear") +