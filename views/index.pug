doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza - Home
    link(rel="stylesheet", href="/css/estilos.css") 
  body
    header
      nav.navbar
        div.nav-logo
          a(href="/") Fotaza
        if nombreUsuario
        div.nav-links
          span.user-badge ¡Hola, @#{nombreUsuario}!
          a.btn-logout(href="/api/usuarios/logout") Cerrar Sesión
    
    main.container
      section.welcome-section
        h2 ¡Bienvenido a tu Feed!
        p Ya estás dentro de la red social. Acá van a aparecer las próximas publicaciones.