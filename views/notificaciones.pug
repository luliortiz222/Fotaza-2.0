extends layout

block content

  .notifications-container
    h1 Mis Notificaciones

    if notificaciones.length > 0
      .notifications-list
        each n in notificaciones
          .notification-card(class=n.leido ? 'leida' : 'nueva')
            
            .notification-content
              h3.notification-msg= n.mensaje
              if n.createdAt
                span.notification-time
                  |#{new Date(n.createdAt).toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' })}

            .notification-status
              if n.leido
                p.status-read ✔ Leída
              else
                p.status-new 🔔 Nueva

    else
      p.no-notifications No tienes notificaciones por el momento.