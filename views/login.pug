extends layout

block content
  .form-container
    h2 Iniciar Sesión
    p.subtitle ¡Qué bueno verte de nuevo en Fotaza!

    if error
      .alert-error
        p= error

    form(action="/api/usuarios/login" method="POST")

      .form-group
        label(for="email") Correo Electrónico
        input#email(
          type="email"
          name="email"
          placeholder="tu-email@correo.com"
          required
        )

      .form-group
        label(for="password") Contraseña

        .password-wrapper
          input#password(
            type="password"
            name="password"
            placeholder="Entre 4 y 13 caracteres"
            required
            minlength="4"
            maxlength="13"
          )

          button#togglePassword.password-btn(
            type="button"
          ) Ver

      button.btn-submit(type="submit")
        | Ingresar

    p.form-footer
      | ¿No tenés cuenta todavía?
      a(href="/registro") Registrate acá

    script(src="/js/password-helper.js")