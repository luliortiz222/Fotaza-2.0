extends layout

block content

  .form-container
    h2 NUEVA FOTO
    p.subtitle Compartí un momento especial

    if error
      .alert-error
        p= error

    form(action="/api/publicaciones/crear" method="POST" enctype="multipart/form-data")

      .form-group
        label(for="titulo") Título
        input#titulo(
          type="text"
          name="titulo"
          placeholder="Dale un título genial..."
          required
        )

      .form-group
        label(for="imagen") Imagen

        label.btn-archivo(for="imagen")
          |  Seleccionar imagen

        input#imagen(
          type="file"
          name="imagen"
          accept="image/*"
          required
        )

        #preview-container
          img#preview-image

      .form-group
        label(for="descripcion") Descripción
        input#descripcion(
          type="text"
          name="descripcion"
          placeholder="¿Qué está pasando aquí?"
        )

      .form-group
        label(for="etiquetas") Etiquetas
        input#etiquetas(
          type="text"
          name="etiquetas"
          placeholder="ej: arte, viaje, amigos"
        )

      button.btn-submit(type="submit")
        | Publicar Foto

  script.
    document.getElementById('imagen').addEventListener('change', function() {
      const file = this.files[0];
      const previewContainer = document.getElementById('preview-container');
      const previewImage = document.getElementById('preview-image');
      const btn = document.querySelector('.btn-archivo');

      if (file) {
        const reader = new FileReader();

        reader.onload = function(e) {
          previewImage.src = e.target.result;
          previewContainer.style.display = 'block';
          btn.textContent = '📸 Cambiar imagen';
        }

        reader.readAsDataURL(file);
      }
    });