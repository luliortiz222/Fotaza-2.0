extends layout

block content
  .colecciones-container
    h1 Mis Colecciones

    form.form-coleccion(action="/api/colecciones" method="POST")
      input(
        type="text"
        name="nombre"
        placeholder="Nombre de la colección"
        required
      )
      button(type="submit") Crear colección

    if colecciones && colecciones.length > 0
      .colecciones-grid
        each coleccion in colecciones
          .coleccion-card
            .icono 📁
            h3= coleccion.nombre

            if coleccion.publicaciones && coleccion.publicaciones.length > 0
              .publicaciones-grid
                each pub in coleccion.publicaciones
                  .pub-card
                    img(src=pub.urlImagen, alt=pub.titulo)
                    .card-body
                      h4= pub.titulo
                      p= pub.descripcion
                      p.user-tag @#{pub.Usuario ? pub.Usuario.usuario : 'Anónimo'}
            else
              p Esta colección está vacía.
    else
      p.sin-colecciones No tienes colecciones creadas.